{
  "name": "@florianjs/mintui",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "description": "A compact, modern UI component library for Nuxt 4 + TailwindCSS with light and dark mode.",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.mjs"
    },
    "./nuxt": {
      "import": "./dist/nuxt.mjs"
    },
    "./style.css": "./dist/style.css",
    "./mcp": "./dist/mcp-server.mjs"
  },
  "bin": {
    "mintui-mcp": "./dist/mcp-server.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "files": [
    "dist/*.mjs",
    "dist/style.css",
    "docs",
    "app/components/Ui",
    "app/assets/css"
  ],
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@nuxt/kit": "^3.17.0"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@storybook-vue/nuxt": "^9.0.1",
    "@storybook/addon-a11y": "~10.2.16",
    "@storybook/addon-docs": "~10.2.16",
    "@storybook/addon-themes": "~10.2.16",
    "@storybook/vue3": "^10.2.16",
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "nuxt": "^4.3.1",
    "postcss": "^8.5.8",
    "storybook": "~10.2.16",
    "tailwindcss": "^3.4.19",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4"
  }
}
